{
  "name": "@unifetch/fortnox",
  "version": "1.0.0",
  "description": "TypeScript SDK for the Fortnox API, with full type safety generated from the official OpenAPI specification.",
  "main": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "download": "tsx src/lib/downloader.ts",
    "test:typegen": "pnpm run test:patch && openapi-ts",
    "test:download": "tsx scripts/download-official-spec.ts",
    "test:patch": "tsx scripts/patch-spec.ts"
  },
  "keywords": ["fortnox", "api", "openapi", "typescript", "sdk"],
  "author": "Rajorshi Roy",
  "repository": {
    "type": "git",
    "url": "https://github.com/royz/fortnox"
  },
  "license": "ISC",
  "files": [
    "dist"
  ],
  "packageManager": "pnpm@10.12.2",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "dotenv": "^17.3.1",
    "tsdown": "^0.21.7",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "@biomejs/biome": "^2.4.10",
    "json-schema-to-typescript": "^15.0.4"
  }
}