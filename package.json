{
	"name": "@unifetch/fortnox",
	"version": "2.11.0",
	"description": "TypeScript SDK for the Fortnox API, with full type safety generated from the official OpenAPI specification.",
	"type": "module",
	"scripts": {
		"generate": "tsx scripts/generate.ts",
		"postgenerate": "biome check --write ./src/types ./overrides",
		"build": "tsdown",
		"biome:check": "biome check --write",
		"changeset": "changeset",
		"version": "changeset version",
		"ship": "tsx scripts/release.ts"
	},
	"keywords": [
		"fortnox",
		"api",
		"openapi",
		"typescript",
		"sdk"
	],
	"author": "Rajorshi Roy",
	"repository": {
		"type": "git",
		"url": "https://github.com/royz/fortnox"
	},
	"bugs": {
		"url": "https://github.com/royz/fortnox/issues"
	},
	"license": "ISC",
	"files": [
		"dist",
		"CHANGELOG.md"
	],
	"packageManager": "pnpm@10.12.2",
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@changesets/cli": "^2.30.0",
		"@types/node": "^25.5.0",
		"dotenv": "^17.3.1",
		"json-schema-to-typescript": "^15.0.4",
		"openapi-types": "^12.1.3",
		"tsdown": "^0.21.7",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	},
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./mini": {
			"import": {
				"types": "./dist/mini.d.mts",
				"default": "./dist/mini.mjs"
			},
			"require": {
				"types": "./dist/mini.d.cts",
				"default": "./dist/mini.cjs"
			}
		},
		"./utils": {
			"import": {
				"types": "./dist/exported-utils.d.mts",
				"default": "./dist/exported-utils.mjs"
			},
			"require": {
				"types": "./dist/exported-utils.d.cts",
				"default": "./dist/exported-utils.cjs"
			}
		},
		"./custom-types": {
			"import": {
				"types": "./dist/types/custom/index.d.mts"
			},
			"require": {
				"types": "./dist/types/custom/index.d.cts"
			}
		},
		"./official-schemas": {
			"import": {
				"types": "./dist/types/official-schemas.gen.d.mts"
			},
			"require": {
				"types": "./dist/types/official-schemas.gen.d.cts"
			}
		},
		"./patched-schemas": {
			"import": {
				"types": "./dist/types/patched-schemas.gen.d.mts"
			},
			"require": {
				"types": "./dist/types/patched-schemas.gen.d.cts"
			}
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.cts",
	"publishConfig": {
		"access": "public"
	}
}
